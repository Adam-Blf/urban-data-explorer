# --- Storage roots (override only if you move the data lake) ---
DATA_LAKE_ROOT=./data
RAW_DIR=./data/raw
SILVER_DIR=./data/silver
GOLD_DIR=./data/gold
LOGS_DIR=./logs

# --- Gold relational store ---
GOLD_DUCKDB_PATH=./data/gold/urban.duckdb

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=change-me-in-prod-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=60
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500

# --- Demo credentials (replace before deploy) ---
DEMO_USER=admin
DEMO_PASSWORD=admin

# --- Sources (override only if endpoints change) ---
DVF_BASE_URL=https://files.data.gouv.fr/geo-dvf/latest/csv
PARIS_OPENDATA_BASE_URL=https://opendata.paris.fr/api/explore/v2.1/catalog/datasets
INSEE_FILOSOFI_URL=https://www.insee.fr/fr/statistiques/fichier/8229323/cc_filosofi_2021_COM.csv
ARRONDISSEMENTS_GEOJSON_URL=https://opendata.paris.fr/api/explore/v2.1/catalog/datasets/arrondissements/exports/geojson
AIRPARIF_URL=https://opendata.paris.fr/api/explore/v2.1/catalog/datasets/qualite-de-lair-mesuree-dans-la-station-paris-centre/exports/json
